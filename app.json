{
  "expo": {
    "name": "Alô Mundo - React Native",
    "slug": "alomundo-react-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    // "newArchEnabled": false,
    "scheme": "alomundo",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6C63FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ads.alomundo"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6C63FF"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.ads.alomundo"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "description": "Exemplo educacional de React Native com Expo para alunos de ADS"
  }
}
